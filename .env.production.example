APP_NAME="GRC Platform"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://grc.example.com

APP_LOCALE=pl
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning

# MySQL
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=grctool
DB_USERNAME=grctool
DB_PASSWORD=ZMIEN_TO_NA_SILNE_HASLO
DB_ROOT_PASSWORD=ZMIEN_TO_NA_SILNE_HASLO_ROOT

# Sesja (HTTPS only)
SESSION_DRIVER=database
SESSION_LIFETIME=240
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict
SESSION_HTTP_ONLY=true

# Queue
QUEUE_CONNECTION=database

# Mail (Amazon SES / Mailgun / SMTP)
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="grc@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# BCRYPT cost (higher = secure but slower)
BCRYPT_ROUNDS=12

# Hash
HASH_DRIVER=argon2id
HASH_VERIFY=true
