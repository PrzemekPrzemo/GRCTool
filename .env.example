APP_NAME="GRC Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

APP_LOCALE=pl
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pl_PL

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Dev: SQLite
DB_CONNECTION=sqlite
# Prod: MySQL
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=grctool
# DB_USERNAME=grctool
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=240
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true  # Requires HTTPS — set to false only for local HTTP dev
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="grc@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Google OAuth (Google Workspace SSO)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback
GOOGLE_WORKSPACE_DOMAIN=yourdomain.com  # Restrict OAuth to this Google Workspace domain

# Microsoft Entra ID (Azure AD) SSO — can also be configured via Admin → Entra ID / SSO panel
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=common
AZURE_REDIRECT_URI=https://yourdomain.com/auth/microsoft/callback

# Google Drive integration for Policies (documents/versioning) is configured entirely via
# Admin → Google Drive panel (service account JSON, folder ID, enable/disable API sync).
# No .env variables are required — the "manual link" mode works with zero configuration.

# Security connectors (Entra ID Identity Protection, Google Workspace Alert Center,
# AWS Security Hub) are configured entirely via their Admin panels — no .env variables
# required. They ingest risk signals into the Incidents/Vulnerabilities registers hourly.

SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#security-alerts
SLACK_ENABLED=false
